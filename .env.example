# --- LLM mode ---
# Set to "true" on AWS (uses Bedrock), "false" locally (uses Anthropic API directly)
USE_BEDROCK=false

# --- Local mode (USE_BEDROCK=false) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- AWS / Bedrock mode (USE_BEDROCK=true) ---
# Credentials not needed on EC2 with an IAM instance role
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# Bedrock model ID — verify in AWS Console → Amazon Bedrock → Model access
BEDROCK_PRIMARY_MODEL=us.anthropic.claude-sonnet-4-5-20250514-v1:0

# --- Amazon Transcribe (required for audio file uploads) ---
# Create an S3 bucket in the same region; the IAM role needs s3:PutObject + transcribe:* permissions
S3_BUCKET=your-s3-bucket-name
